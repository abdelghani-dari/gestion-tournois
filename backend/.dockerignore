# Git
.git
.gitignore

# Environment secrets - NEVER in image
.env
.env.*
!.env.example

# Dependencies (rebuilt inside image by composer install)
vendor/

# Symlink - cannot be copied by Docker (recreated at runtime via storage:link)
public/storage

# Laravel cache/logs - generated at runtime
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*

# Dev tools
.phpunit.cache
phpunit.xml
tests/

# Docker files themselves
Dockerfile
docker-compose*

# OS files
.DS_Store
Thumbs.db
